# =====================================================
# CropGuard AI — .gitignore
# =====================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyd
*.pyo
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Streamlit secrets (NEVER commit!)
.streamlit/secrets.toml
.streamlit/cache/

# =====================================================
# LARGE MODEL FILES (use Git LFS or HuggingFace Hub)
# =====================================================
# yield_model.pkl is 263 MB — tracked via Git LFS
# (see .gitattributes)

# =====================================================
# Large Datasets
# =====================================================
data/raw/
crop_data/
*.zip
*.tar.gz
*.tar.bz2

# Output artifacts (not needed in repo)
outputs/mlruns/
outputs/*.png
outputs/*.jpg

# Old model directories
new_models/
syn_models/
fao_models/
pv_models/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment variables
.env
.env.local
.env.production

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
logs/